# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=3001

# ─── Frontend ────────────────────────────────────────────────────────────────
# URL of your backend API (change to Railway URL in production)
VITE_API_URL=http://localhost:3001

# ─── Railway ─────────────────────────────────────────────────────────────────
# Get from https://railway.app → Account Settings → Tokens
RAILWAY_TOKEN=your-railway-token-here

# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_REPO_URL=https://github.com/Eliranshopen/smart-decision-engine

# ─── Affiliate Program IDs ───────────────────────────────────────────────────
# These are YOUR unique tracking IDs — sign up at each platform to get them:
#
# ShareASale: https://www.shareasale.com/info/merchant.cfm
# TODO: Replace with your ShareASale affiliate ID after signing up
AFFILIATE_ID_SHAREASALE=TODO_your_shareasale_id

# CJ Affiliate (Commission Junction): https://www.cj.com
# TODO: Replace with your CJ affiliate ID after signing up
AFFILIATE_ID_CJ=TODO_your_cj_id

# ClickBank: https://www.clickbank.com/affiliate-program/
# TODO: Replace with your ClickBank nickname/ID after signing up
AFFILIATE_ID_CLICKBANK=TODO_your_clickbank_id

# PartnerStack: https://partnerstack.com
# TODO: Replace with your PartnerStack affiliate ID after signing up
AFFILIATE_ID_PARTNERSTACK=TODO_your_partnerstack_id

# Impact: https://impact.com/affiliates/
# TODO: Replace with your Impact affiliate ID after signing up
AFFILIATE_ID_IMPACT=TODO_your_impact_id

# ─── AI (Optional — for enhanced agent analysis) ────────────────────────────
# OpenAI key used by CrewAI agents for LLM reasoning
# TODO: Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=TODO_your_openai_api_key
